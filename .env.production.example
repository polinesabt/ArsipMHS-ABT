# Production Configuration Template
# Copy this file to .env.production on the server (do not commit real values)

# Frontend API Configuration
VITE_API_BASE_URL=https://arsipmhs-abt.com/database/backend/api
VITE_API_TIMEOUT=10000

# Backend Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=<cpanel_db_name>
DB_USER=<cpanel_db_user>
DB_PASS=<rotated_db_password>

# JWT / Auth
JWT_SECRET=<rotated_jwt_secret_hex_64_or_more>
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400
CRON_SECRET=<rotated_cron_secret_hex_64_or_more>

# CORS / Environment
ALLOWED_ORIGIN=https://arsipmhs-abt.com
APP_ENV=production

# Frontend API Configuration
VITE_API_BASE_URL=http://localhost/Arsipmhs2/database/backend/api
VITE_API_TIMEOUT=10000

# Backend API URL
API_BASE_URL=http://localhost/Arsipmhs2/database/backend/api

# Database Configuration (digunakan di backend PHP)
# Note: Backend membaca DB_PASS (bukan DB_PASSWORD)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arsipmhs
DB_USER=root
DB_PASS=

# JWT Configuration
JWT_SECRET=your-generated-jwt-secret-here-change-this-in-production
JWT_EXPIRATION=86400
JWT_ALGORITHM=HS256
CRON_SECRET=your-generated-cron-secret-here

# Environment
NODE_ENV=development

# CORS (production: ganti dengan domain Anda, development: * atau kosongkan)
ALLOWED_ORIGIN=*
APP_ENV=development

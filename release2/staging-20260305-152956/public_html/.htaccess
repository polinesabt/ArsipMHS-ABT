# Pakai file ini saat deploy di root domain (arsipmhs-abt.com).
# Salin ke .htaccess di folder yang jadi document root (isi dist/).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Jangan timpa request ke file/direktori yang ada (termasuk /assets/*)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

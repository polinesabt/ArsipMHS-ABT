# Copy file ini ke .env (di root project, sejajar dengan backend/) lalu isi nilai asli.
# Jangan commit .env ke git (berisi rahasia).

# --- Frontend (Vite) - untuk development di .env, untuk build production di .env.production ---
# Base path: / untuk production root, /Arsipmhs2/ untuk development subpath di XAMPP
VITE_APP_BASE=/Arsipmhs2/
# URL API penuh (production). Kosong = deteksi otomatis dari origin + path
VITE_API_BASE_URL=
# Hanya development: target proxy /api (default http://localhost/Arsipmhs2/backend/api)
# VITE_DEV_API_TARGET=http://localhost/Arsipmhs2/backend/api

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arsipmhs
DB_USER=root
DB_PASS=

# --- JWT / Auth ---
JWT_SECRET=your-jwt-secret-key-min-32-chars

# --- Aplikasi ---
APP_ENV=development
ALLOWED_ORIGIN=*
# URL frontend (untuk link verifikasi email). Contoh: http://localhost:5173 atau http://localhost/Arsipmhs2
FRONTEND_BASE_URL=

# --- Email verifikasi login mahasiswa (SMTP) ---
# Driver: smtp (kirim beneran) atau mail (PHP mail())
EMAIL_DRIVER=smtp
EMAIL_FROM=no-reply@arsipmhs-abt.com
EMAIL_FROM_NAME=Arsip Mahasiswa ABT
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=tls
# Gmail: gunakan App Password, bukan password akun biasa. Buat di: https://myaccount.google.com/apppasswords
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
# Development: jika 1, saat SMTP gagal link verifikasi tetap ditulis ke log (backend/storage/logs/email_login.log) dan API tetap sukses.
EMAIL_DEV_FALLBACK_ENABLED=1
# Opsional: masa berlaku token (detik). Default 1800 (30 menit).
# EMAIL_LOGIN_TOKEN_TTL=1800
# Opsional: cooldown kirim ulang (detik). Default 60.
# EMAIL_LOGIN_RESEND_COOLDOWN=60
